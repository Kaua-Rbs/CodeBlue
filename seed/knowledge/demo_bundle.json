  "evidence_statements": [
    {
      "evidence_statement_id": "evidence_hospital_onset_demo_001",
      "statement": "Influenza confirmed after a hospital-onset threshold should trigger infection-control review.",
      "evidence_type": "guideline_translation",
      "source_document_ids": ["src_cdc_influenza_hc_001"],
      "confidence": "high",
      "uncertainty_note": "Local thresholds may vary by institution.",
      "applies_to": ["influenza", "hospital_onset", "review_workflow"],
      "used_by_rule_ids": [
        "rule_influenza_hospital_onset_case",
        "review_isolation_placement_for_hospital_onset_influenza"
      ]
    }
  ],
  "rule_artifacts": [
    {
      "rule_id": "rule_influenza_hospital_onset_case",
      "rule_kind": "case_definition",
      "owner_pack_id": "pathogen_influenza_a_v1",
      "name": "Hospital-onset influenza case",
      "description": "Confirmed influenza occurring after hospital-onset threshold.",
      "priority": 100,
      "enabled": true,
      "condition": {
        "all": [
          { "fact": "lab.confirmed_pathogen", "op": "eq", "value": "influenza" },
          { "fact": "encounter.hours_since_admission", "op": "gt", "value": 96 }
        ]
      },
      "outputs": [
        {
          "type": "classification",
          "key": "case_classification",
          "value": "hospital_onset_influenza"
        }
      ],
      "source_document_ids": ["src_cdc_influenza_hc_001"],
      "confidence": "high",
      "version": "1.0.0"
    },
    {
      "rule_id": "review_isolation_placement_for_hospital_onset_influenza",
      "rule_kind": "review_rule",
      "owner_pack_id": "workflow_general_demo_v1",
      "name": "Review isolation placement for hospital-onset influenza",
      "description": "Route isolation review to infection prevention control.",
      "priority": 100,
      "enabled": true,
      "condition": {
        "all": [
          {
            "fact": "classification.case_classification",
            "op": "eq",
            "value": "hospital_onset_influenza"
          }
        ]
      },
      "outputs": [
        {
          "type": "proposed_action",
          "action_id": "action_review_isolation_placement",
          "review_team": "infection_prevention_control",
          "urgency": "high"
        }
      ],
      "source_document_ids": ["src_cdc_influenza_hc_001"],
      "confidence": "high",
      "version": "1.0.0"
    },
    {
      "rule_id": "policy_no_auto_medication_orders",
      "rule_kind": "policy_constraint",
      "owner_pack_id": "policy_general_hospital_demo_v1",
      "name": "No autonomous medication ordering",
      "description": "Medication actions must remain review only.",
      "priority": 100,
      "enabled": true,
      "condition": {
        "all": [
          { "fact": "proposed_action.category", "op": "eq", "value": "medication" }
        ]
      },
      "outputs": [
        {
          "type": "constraint",
          "key": "execution_mode",
          "value": "review_only"
        }
      ],
      "source_document_ids": ["src_cdc_influenza_hc_001"],
      "confidence": "high",
      "version": "1.0.0"
    },
    {
      "rule_id": "policy_log_infection_control_actions",
      "rule_kind": "policy_constraint",
      "owner_pack_id": "policy_general_hospital_demo_v1",
      "name": "All infection control actions must be logged",
      "description": "Apply an explicit logging constraint to surfaced infection control actions.",
      "priority": 90,
      "enabled": true,
      "condition": {
        "all": [
          { "fact": "proposed_action.category", "op": "eq", "value": "infection_control" }
        ]
      },
      "outputs": [
        {
          "type": "constraint",
          "key": "audit_mode",
          "value": "must_log"
        }
      ],
      "source_document_ids": ["src_cdc_influenza_hc_001"],
      "confidence": "moderate",
      "version": "1.0.0"
    }
  ],
  "action_catalog": [
    {
      "action_id": "action_review_isolation_placement",
      "display_name": "Review isolation placement",
      "category": "infection_control",
      "subtype": "patient_placement_review",
